# Fast zsh config based on your current ~/.zshrc

# PATH (deduplicated, fast)
typeset -U path PATH
path=(
  "$HOME/.local/bin"
  "$HOME/.lmstudio/bin"
  "$HOME/bin"
  "/usr/local/bin"
  $path
)

# Core Environment
export EDITOR="nvim"
export VISUAL="nvim"
export PAGER="bat"

# Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="sporty_256"

# Completion / behavior
CASE_SENSITIVE="true"
ENABLE_CORRECTION="true"

# History tuning (without OMZ history plugin)
HISTSIZE=100000
SAVEHIST=100000
HISTFILE="$HOME/.zsh_history"

setopt APPEND_HISTORY
setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS

# Faster + safer OMZ updates than fully automatic updates
zstyle ':omz:update' mode reminder
zstyle ':omz:update' frequency 13

# Big speed win in large git repos
DISABLE_UNTRACKED_FILES_DIRTY="true"

# Keep plugin set minimal
zstyle ':omz:plugins:git' alias-type no-alias
plugins=(git sudo colored-man-pages)

# Add zsh-completions to fpath before sourcing OMZ
fpath+=${ZSH_CUSTOM:-${ZSH:-~/.oh-my-zsh}/custom}/plugins/zsh-completions/src

source "$ZSH/oh-my-zsh.sh"

# Load syntax highlighting (best to load it AFTER oh-my-zsh)
if [[ -f "${ZSH_CUSTOM:-$ZSH/custom}/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]]; then
  source "${ZSH_CUSTOM:-$ZSH/custom}/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
  ZSH_HIGHLIGHT_HIGHLIGHTERS=(main brackets pattern cursor)
fi

# fzf integration (guarded)
if [[ -o interactive ]] && command -v fzf >/dev/null 2>&1; then
  source <(fzf --zsh)
  # FZF improvements: Bigger window, preview, and open in nvim on Enter for plain fzf
  export FZF_DEFAULT_OPTS="--height 80% --layout=reverse --border --preview 'bat --color=always --style=plain --line-range=:500 {}' --bind 'enter:execute(nvim {})+abort'"
  # Ensure widgets keep their default behavior (don't open nvim)
  export FZF_CTRL_T_OPTS="--bind 'enter:accept'"
  export FZF_ALT_C_OPTS="--bind 'enter:accept' --preview 'ls -F --color=always {}'"
  # Fix zoxide (zi) to jump instead of opening nvim
  export _ZO_FZF_OPTS="--bind 'enter:accept' --preview 'ls -F --color=always {}' --height 80% --layout=reverse --border"
fi

# Lazy Conda init: loads only when you actually run `conda`
if [[ -f "$HOME/anaconda3/etc/profile.d/conda.sh" ]]; then
  conda() {
    unset -f conda
    source "$HOME/anaconda3/etc/profile.d/conda.sh"
    conda "$@"
  }
elif [[ -x "$HOME/anaconda3/bin/conda" ]]; then
  # Fallback if conda.sh is missing
  path=("$HOME/anaconda3/bin" $path)
fi

# External tool initializations
eval "$(zoxide init zsh)"
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv zsh)"
eval "$(atuin init zsh --disable-up-arrow)"
